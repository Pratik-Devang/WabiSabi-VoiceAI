# Required: create backend/.env and add your own key.
GEMINI_API_KEY=

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# Gemini Live
LIVE_MODEL=gemini-3.1-flash-live-preview
FOLLOWUP_MODEL=gemini-3.6-flash
VOICE_NAME=Kore
COMPRESSION_TRIGGER_TOKENS=25000
COMPRESSION_TARGET_TOKENS=8000

# RAG
KNOWLEDGE_BASE_DIR=../_reference/gemini-live-api-tts/knowledge_base
CHROMA_PERSIST_DIR=./chroma_data
RAG_COLLECTION_NAME=knowledge_base
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
